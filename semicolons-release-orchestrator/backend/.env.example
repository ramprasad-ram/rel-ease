# Release Orchestration Platform - Environment Configuration

# Application Settings
APP_NAME=Release Orchestration Platform
APP_VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite+aiosqlite:///./release_orchestrator.db
DATABASE_ECHO=false

# Mock CI/CD Settings
MOCK_CICD_ENABLED=true
MOCK_CICD_DELAY_MIN=2
MOCK_CICD_DELAY_MAX=5
MOCK_CICD_FAILURE_RATE=0.1

# AI Agent Settings
AI_AGENT_ENABLED=true
AI_AGENT_CONFIDENCE_THRESHOLD=0.7
AI_AGENT_TIMEOUT=30

# Workflow Settings
WORKFLOW_MAX_RETRIES=3
WORKFLOW_RETRY_DELAY=5

# Slack Integration (for Autonomous Rollback Agent)
# Get your webhook URL from: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ENABLED=false

# Rollback Agent Settings
ROLLBACK_AGENT_ENABLED=true
ROLLBACK_ERROR_THRESHOLD=0.15
ROLLBACK_CRITICAL_THRESHOLD=0.30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100